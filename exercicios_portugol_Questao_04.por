programa {
  funcao inicio() {
    escreva("Passo 1: Pegue duas fatias de pão.\n")
    escreva("Passo 2: Passe maionese em uma fatia.\n")
    escreva("Passo 3: Adicione queijo e presunto.\n")
    escreva("Passo 4: Feche com a outra fatia de pão.\n")
    escreva("Passo 5: Sirva o sanduíche!")
  }
}